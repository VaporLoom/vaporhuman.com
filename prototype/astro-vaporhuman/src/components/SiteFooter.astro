---
import { site } from "../data/site";

const measurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const analyticsEnabled =
  typeof measurementId === "string" && /^G-[A-Z0-9-]+$/i.test(measurementId);
---

<footer class="site-footer">
  <div class="footer-wrap">
    <section class="footer-notes" aria-label="Important site notes">
      <p>
        VaporHuman designs private AI continuity systems. Site copy, page
        structure, availability, and future features may change as the product
        lane develops.
      </p>
      <p>
        This site does not provide medical, legal, financial, employment,
        identity, emergency, or regulated advice. Assistant output should
        support human judgment, not replace it.
      </p>
      <p>
        The work-intake path uses a hosted Tally form, and paid discovery uses
        a hosted Stripe Payment Link. This site does not embed forms, login,
        checkout, public email address, public support flow, subscriptions, or live
        assistant service.
        {analyticsEnabled
          ? " Optional Google Analytics measurement loads only after a visitor allows analytics."
          : " This build does not include analytics or tracking scripts."}
      </p>
    </section>

    <nav class="footer-grid" aria-label="Footer navigation">
      <section>
        <h2>Explore</h2>
        <ul>
          {site.footerExplore.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </section>
      <section>
        <h2>Current posture</h2>
        <ul>
          <li>Production pages first</li>
          <li>Hosted intake before automation</li>
          <li>Hosted payment before embeds</li>
          <li>Provider gates before subscriptions</li>
        </ul>
      </section>
      <section>
        <h2>Trust reminders</h2>
        <ul>
          <li>Human approval matters</li>
          <li>Memory can be incomplete</li>
          <li>Claims should be checkable</li>
          <li>Private context stays private</li>
        </ul>
      </section>
      <section>
        <h2>Site files</h2>
        <ul>
          {site.footerFiles.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </section>
    </nav>

    <div class="footer-bottom">
      <p>Copyright &copy; 2026 VaporHuman. All rights reserved.</p>
      <p>United States</p>
    </div>
  </div>
</footer>
