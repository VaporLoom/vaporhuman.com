---
import { site } from "../data/site";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const accountPortalUrl = import.meta.env.PUBLIC_ACCOUNT_PORTAL_URL;
const accountPortalEnabled =
  typeof accountPortalUrl === "string" && /^https:\/\/[a-z0-9.-]+(?:\/.*)?$/i.test(accountPortalUrl);
---

<header class="site-header" aria-label="Site header">
  <a class="brand" href="/">VaporHuman</a>
  <div class="header-actions">
    <nav class="site-nav" aria-label="Primary navigation">
      {site.nav.map((item) => (
        <a
          href={item.href}
          aria-current={currentPath === item.href ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <nav class="utility-nav" aria-label="Account and preference navigation">
      {site.utilityActions.map((item) => (
        accountPortalEnabled && item.action === "account" ? (
          <a
            class="utility-link"
            href={accountPortalUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open the private account portal"
          >
            {item.label}
          </a>
        ) : (
          <button
            class="utility-link"
            type="button"
            disabled
            data-action={item.action}
            aria-label={`${item.label} application action placeholder`}
          >
            {item.label}
          </button>
        )
      ))}
      {site.utilityControls.map((control) => (
        <button
          class="utility-select"
          type="button"
          disabled
          aria-label={`${control.label} selector placeholder`}
        >
          <span>{control.value}</span>
          <span aria-hidden="true">v</span>
        </button>
      ))}
    </nav>
  </div>
</header>
