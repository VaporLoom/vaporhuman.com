---
import { site } from "../data/site";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const accountPortalUrl = import.meta.env.PUBLIC_ACCOUNT_PORTAL_URL;
const accountPortalEnabled =
  typeof accountPortalUrl === "string" && /^https:\/\/[a-z0-9.-]+(?:\/.*)?$/i.test(accountPortalUrl);
---

<header class="site-header" aria-label="Site header">
  <a class="brand" href="/">
    <img
      class="brand-mark"
      src="/vaporhuman-icon-white.svg"
      alt=""
      width="28"
      height="28"
      decoding="async"
      aria-hidden="true"
    />
    <span>VaporHuman</span>
  </a>
  <div class="header-actions">
    <nav class="site-nav" aria-label="Primary navigation">
      {site.nav.map((item) => (
        <a
          href={item.href}
          aria-current={currentPath === item.href ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
    {accountPortalEnabled && (
      <nav class="utility-nav" aria-label="Account navigation">
        {site.utilityActions.map((item) => (
          item.action === "account" && (
          <a
            class="utility-link"
            href={accountPortalUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open the private account portal"
          >
            {item.label}
          </a>
          )
        ))}
      </nav>
    )}
  </div>
</header>
