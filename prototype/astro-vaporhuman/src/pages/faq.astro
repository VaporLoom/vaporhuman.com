---
import Band from "../components/Band.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const description = "Frequently asked questions about the current VaporHuman site.";
const cards = [
  { group: "Site", title: "What is VaporHuman?", body: "A public trust surface for private AI continuity systems, human approval gates, memory boundaries, and assistant handoffs." },
  { group: "Site", title: "Is this a full product launch?", body: "No. This is an early static site with clear provider-hosted routes and restrained public claims." },
  { group: "Accounts", title: "Can I create an account?", body: "No. There is no login, dashboard, account system, or live assistant service here." },
  { group: "Work", title: "Can I contact VaporHuman?", body: "Yes, for work requests through the hosted Tally intake link on the Work page. No public email address is active." },
  { group: "Payments", title: "How does paid discovery work?", body: "The paid discovery route opens a Stripe-hosted payment page. The site does not embed checkout or process card data." },
  { group: "Trust", title: "Does this provide regulated advice?", body: "No. It is not medical, legal, financial, employment, identity, or emergency advice." },
  { group: "Privacy", title: "Does the site track visitors?", body: "This build does not include analytics scripts, tracking pixels, hidden forms, cookies, or social embeds." },
  { group: "Shop", title: "Where does the shop go?", body: "The shop link opens Fourthwall externally. Fourthwall handles storefront checkout and shop support." }
];
---

<BaseLayout title="FAQ" description={description} canonicalPath="/faq.html" currentPath="/faq.html">
  <PageHero
    kicker="FAQ"
    title="Current answers, without overclaiming."
    lede="A small set of answers for what this site is, what it is not, and what is not active yet."
  />

  <Band variant="intro" kicker="FAQ" title="Open the answer you need." id="faq-title">
    <div class="faq-list" aria-label="Frequently asked questions">
      {cards.map((card, index) => (
        <details class="faq-item" open={index === 0}>
          <summary>
            <span>{card.group}</span>
            {card.title}
          </summary>
          <p>{card.body}</p>
        </details>
      ))}
    </div>
  </Band>

  <Band variant="boundary" kicker="Still true" title="The human remains responsible for decisions." id="boundary-title" columns>
    <p>
      VaporHuman can describe safer assistant patterns, but it does not make AI
      output automatically true, safe, complete, private, or appropriate for
      every context.
    </p>
  </Band>
</BaseLayout>
