---
import Band from "../components/Band.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout
  title="VaporHuman"
  canonicalPath="/"
  currentPath="/"
>
  <PageHero
    home
    kicker="Private AI continuity systems"
    title="VaporHuman"
    lede="A public trust surface for the private operating layer behind serious AI-assisted work."
    body="VaporHuman turns scattered sessions, repo state, approvals, and handoffs into a readable workflow where assistant output supports human judgment."
  >
    <div class="button-row" aria-label="Featured pages">
      <a class="button" href="/work.html">Work with VaporHuman</a>
      <a class="button button--ghost" href="/trust.html">Review the trust boundary</a>
    </div>
    <div class="hero-map" aria-label="Continuity map preview">
      <span>Context</span>
      <span>Memory</span>
      <span>Handoff</span>
      <span>Approval</span>
    </div>
  </PageHero>

  <Band
    variant="intro"
    kicker="Control room"
    title="From scattered context to a usable private workflow."
    id="workflow-map"
  >
    <div class="system-console" aria-label="Workflow transformation preview">
      <div class="console-column">
        <p class="status-label">Scattered state</p>
        <ul class="signal-list">
          <li>Useful notes trapped in old sessions</li>
          <li>Unclear source of confidence</li>
          <li>Assistant output waiting for review</li>
          <li>Private details mixed with public drafts</li>
        </ul>
      </div>
      <div class="map-core" aria-hidden="true">
        <span class="map-node node-a"></span>
        <span class="map-node node-b"></span>
        <span class="map-node node-c"></span>
        <span class="map-node node-d"></span>
        <span class="map-line line-a"></span>
        <span class="map-line line-b"></span>
        <span class="map-line line-c"></span>
        <strong>Human checkpoint</strong>
      </div>
      <div class="console-column">
        <p class="status-label">Readable workflow</p>
        <ul class="signal-list">
          <li>Reusable context with boundaries</li>
          <li>Known, uncertain, and private marked clearly</li>
          <li>Handoffs ready for the next assistant or human</li>
          <li>Approval gates before public or provider action</li>
        </ul>
      </div>
    </div>
  </Band>

  <Band kicker="Decision boundary" title="Choose the work state and see the next boundary." id="decision-boundary">
    <div class="decision-grid">
      <details class="decision-card" open>
        <summary>
          <span>Scattered context</span>
          <strong>Build continuity before more output.</strong>
        </summary>
        <div class="decision-body">
          <p><strong>Assistant may draft:</strong> source maps, handoff notes, summaries, and next-step options.</p>
          <p><strong>Human approves:</strong> what becomes durable memory, what leaves the workspace, and what stays parked.</p>
          <p><strong>Stays private:</strong> secrets, raw sessions, provider screens, payment data, private messages, and unreviewed identity details.</p>
        </div>
      </details>
      <details class="decision-card">
        <summary>
          <span>Public claim</span>
          <strong>Separate draft language from publication.</strong>
        </summary>
        <div class="decision-body">
          <p><strong>Assistant may draft:</strong> restrained copy, claim checks, evidence gaps, and launch checklists.</p>
          <p><strong>Human approves:</strong> final wording, publication, provider changes, and rollback posture.</p>
          <p><strong>Stays private:</strong> unverified evidence, internal review notes, customer data, and private governance material.</p>
        </div>
      </details>
      <details class="decision-card">
        <summary>
          <span>Operational handoff</span>
          <strong>Make the next operator visible.</strong>
        </summary>
        <div class="decision-body">
          <p><strong>Assistant may draft:</strong> task packets, acceptance checks, status summaries, and route options.</p>
          <p><strong>Human approves:</strong> commits, provider action, public exposure, payments, and workflow authority.</p>
          <p><strong>Stays private:</strong> raw logs, credentials, local configs, private account data, and sensitive personal context.</p>
        </div>
      </details>
    </div>
  </Band>

  <Band
    variant="boundary"
    kicker="What this is not"
    title="Not A Substitute For Human Judgment"
    id="not-title"
  >
    <p>
      VaporHuman is not a person, therapist, doctor, lawyer, accountant,
      employer, identity service, emergency service, or authority over human
      decisions.
    </p>
    <p>
      It does not promise that AI is always right, always safe, private by
      default, always available, or a substitute for human judgment.
    </p>
  </Band>

  <Band kicker="Routes" title="The public site points to the right boundary before the next step." id="routes-title">
    <div class="route-grid">
      <a class="route-card" href="/work.html">
        <span>Work</span>
        <strong>Pick the service lane and use hosted intake.</strong>
      </a>
      <a class="route-card" href="/trust.html">
        <span>Trust</span>
        <strong>Check what is known, uncertain, private, and approval-gated.</strong>
      </a>
      <a class="route-card" href="/games.html">
        <span>Play</span>
        <strong>Try VaporPong as a free static browser prototype.</strong>
      </a>
      <a class="route-card" href="/about.html">
        <span>About</span>
        <strong>Read the origin sequence without inflated claims.</strong>
      </a>
      <a class="route-card" href="/shop.html">
        <span>Shop</span>
        <strong>Use the external Fourthwall storefront.</strong>
      </a>
    </div>
  </Band>

  <Band kicker="Why it exists" title="Keep the human visible." id="why-title" columns>
    <div>
      <p>AI work gets expensive when every session restarts from zero. VaporHuman goes the other way.</p>
      <p>
        The goal is to make assistant systems more useful in practice: what
        they know, what they do not know, what they are allowed to do, what
        should stay private, and when a human needs to approve the next move.
      </p>
      <p>
        Start with <a href="/work.html">Work with VaporHuman</a>, then read the
        <a href="/trust.html">Trust boundary</a>.
      </p>
    </div>
  </Band>

  <Band variant="status" kicker="Current posture" title="Early, modest, and bounded." id="status-title" columns>
    <div>
      <p>
        The current site is static. Work intake is hosted by Tally, paid
        discovery is hosted by Stripe, and the shop is hosted by Fourthwall.
        There is no embedded login, checkout, tracking script, hidden form, or
        live assistant service in this build.
      </p>
      <p class="principle">Useful first. Honest always. Human in charge.</p>
    </div>
  </Band>
</BaseLayout>
