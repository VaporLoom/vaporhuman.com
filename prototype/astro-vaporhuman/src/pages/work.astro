---
import Band from "../components/Band.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import {
  checkoutTargets,
  conversionGates,
  intakeFields,
  leadIntakeForm,
  paidDiscoveryLink,
  productSelections,
  providerRecommendations
} from "../data/conversion";

const description =
  "Work with VaporHuman on private AI continuity systems, assistant workflow audits, and trust-aware handoff design.";

const offerCards = [
  {
    title: "Assistant workflow audit",
    body:
      "Map what your assistants are doing now, where context is leaking, where sessions restart, and where human approval needs to be clearer.",
    goodFor: "Teams that already use AI and need an evidence-based route from messy output to repeatable work.",
    output: "A workflow map, boundary notes, handoff risks, and the next practical improvement path."
  },
  {
    title: "Private continuity system",
    body:
      "Turn scattered notes, repo state, operating rules, and handoffs into a durable assistant-ready workspace.",
    goodFor: "High-context work that loses time when every assistant session starts over.",
    output: "A local continuity map, memory boundaries, approval gates, and restartable handoff structure."
  },
  {
    title: "Product and support architecture",
    body:
      "Design knowledge base, support bot, dashboard, rate-limit, and member-flow boundaries before providers are connected.",
    goodFor: "Product or support teams planning help centers, AI support lanes, or operator dashboards.",
    output: "A service map, support taxonomy, provider gates, escalation model, and launch constraints."
  },
  {
    title: "Launch readiness review",
    body:
      "Prepare public pages, lead paths, payment gates, measurement posture, and rollback checks before release.",
    goodFor: "Sites, services, and public workflows that need promise control before more visibility.",
    output: "A readiness checklist, claim review, provider boundary check, and rollback notes."
  }
];

const fitCards = [
  {
    title: "Good fit",
    body:
      "You already use AI in real work and need continuity, decision control, private context handling, or repeatable workflows."
  },
  {
    title: "Not a fit",
    body:
      "You need emergency help, regulated advice, hidden tracking, spam outreach, or a system that pretends AI is the decision-maker."
  },
  {
    title: "Private first",
    body:
      "The first production lane should be used internally and with controlled clients before broad public automation."
  }
];
---

<BaseLayout title="Work With VaporHuman" description={description} canonicalPath="/work.html" currentPath="/work.html">
  <PageHero
    kicker="Work with VaporHuman"
    title="Build the AI workflow people can use with judgment intact."
    lede="Private continuity, trust boundaries, and handoff systems for serious AI-assisted work."
    body="The offer is practical: make assistant work restartable, reviewable, and bounded before adding public automation."
  >
    <div class="button-row" aria-label="Work with VaporHuman actions">
      <a class="button" href={leadIntakeForm.url} target="_blank" rel="noopener noreferrer">Start work intake</a>
      <a class="button button--ghost" href={paidDiscoveryLink.url} target="_blank" rel="noopener noreferrer">Book paid discovery</a>
      <a class="button button--ghost" href="/shop.html">Visit the shop</a>
      <a class="button button--ghost" href="/trust.html">Check the boundary</a>
    </div>
  </PageHero>

  <Band variant="intro" kicker="Services" title="Choose the lane that matches the current work." id="services-title">
    <div class="service-selector" aria-label="Service selector">
      {offerCards.map((service, index) => (
        <details class="service-card" open={index === 0}>
          <summary>
            <span>{service.title}</span>
            <strong>{service.body}</strong>
          </summary>
          <div class="service-card__body">
            <p><strong>Good for:</strong> {service.goodFor}</p>
            <p><strong>Typical output:</strong> {service.output}</p>
          </div>
        </details>
      ))}
    </div>
  </Band>

  <Band kicker="Fit" title="Designed for controlled, high-context work." id="fit-title">
    <div class="fit-guide" aria-label="Client fit guide">
      {fitCards.map((card) => (
        <article class="fit-card">
          <p class="status-label">{card.title}</p>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </Band>

  <Band variant="status" kicker="Private intake" title="Use the hosted intake path." id="private-intake" columns>
    <div>
      <p>
        The current intake path is a hosted Tally form for qualified work
        requests. It is meant to capture the company/project, contact details,
        company size, service interest, buying stage, goal, message, and
        consent.
      </p>
      <p>
        The form is external to vaporhuman.com. This source build does not
        embed the form, run analytics, add a CRM endpoint, create accounts, or
        process payments directly.
      </p>
      <div class="button-row" aria-label="Private intake provider action">
        <a class="button" href={leadIntakeForm.url} target="_blank" rel="noopener noreferrer">Open the intake form</a>
      </div>
      <p class="principle">Remote-private first. Public automation second.</p>
    </div>
    <div class="conversion-card">
      <p class="status-label">{leadIntakeForm.status}</p>
      <h3>{leadIntakeForm.title}</h3>
      <p><strong>{leadIntakeForm.provider}</strong></p>
      <p>{leadIntakeForm.body}</p>
      <p>{leadIntakeForm.boundary}</p>
    </div>
  </Band>

  <Band variant="intro" kicker="Paid discovery" title="A first paid step, hosted by Stripe." id="paid-discovery" columns>
    <div>
      <p>
        The first paid service path is a Stripe-hosted discovery session. It is
        for reviewing the request, identifying the useful next step, and
        deciding whether a larger scoped build or invoice makes sense.
      </p>
      <p>
        Stripe hosts the payment page externally. VaporHuman does not handle
        card data, embed checkout, add payment scripts, or activate
        subscriptions in this source build.
      </p>
      <div class="button-row" aria-label="Paid discovery action">
        <a class="button" href={paidDiscoveryLink.url} target="_blank" rel="noopener noreferrer">Book paid discovery</a>
      </div>
    </div>
    <div class="conversion-card">
      <p class="status-label">{paidDiscoveryLink.status}</p>
      <h3>{paidDiscoveryLink.title}</h3>
      <p><strong>{paidDiscoveryLink.provider}</strong></p>
      <p>{paidDiscoveryLink.body}</p>
      <p>{paidDiscoveryLink.boundary}</p>
    </div>
  </Band>

  <Band kicker="Intake shape" title="Lead fields ready for the provider gate." id="intake-fields">
    <div class="intake-preview" aria-label="Future lead intake fields">
      {intakeFields.map((field) => (
        <article class="field-shell">
          <p class="status-label">{field.label}</p>
          <p>{field.example}</p>
        </article>
      ))}
    </div>
  </Band>

  <Band variant="intro" kicker="Selections" title="Product or service routing." id="service-selection">
    <div class="selection-strip" aria-label="Future product and service selections">
      {productSelections.map((selection) => <span>{selection}</span>)}
    </div>
  </Band>

  <Band kicker="Providers" title="Fastest path to leads and income." id="provider-plan">
    <div class="conversion-grid">
      {providerRecommendations.map((item) => (
        <article class="conversion-card">
          <p class="status-label">{item.status}</p>
          <h3>{item.title}</h3>
          <p><strong>{item.provider}</strong></p>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </Band>

  <Band kicker="Checkout" title="Income paths, staged for activation." id="checkout-targets">
    <div class="checkout-grid">
      {checkoutTargets.map((target) => (
        <article class="checkout-card">
          <p class="status-label">{target.status}</p>
          <h3>{target.href ? <a href={target.href} target="_blank" rel="noopener noreferrer">{target.title}</a> : target.title}</h3>
          <p>{target.body}</p>
        </article>
      ))}
    </div>
  </Band>

  <Band variant="boundary" kicker="Provider gates" title="Before leads or money move." id="conversion-gates">
    <ol class="gate-list">
      {conversionGates.map((gate) => <li>{gate}</li>)}
    </ol>
  </Band>
</BaseLayout>
