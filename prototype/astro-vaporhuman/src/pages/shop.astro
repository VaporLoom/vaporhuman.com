---
import Band from "../components/Band.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { fourthwallShop, shopActions } from "../data/conversion";

const description =
  "Shop and support VaporHuman through the existing Fourthwall storefront linked to StreamElements.";
---

<BaseLayout title="Shop" description={description} canonicalPath="/shop.html" currentPath="/shop.html">
  <PageHero
    kicker="Shop"
    title="Support the work through the live Fourthwall shop."
    lede="The current support and storefront route lives outside this site."
    body="Fourthwall handles the storefront and checkout externally. VaporHuman links to it without embedding checkout, cart scripts, tracking pixels, or account behavior."
  >
    <div class="button-row" aria-label="Shop actions">
      <a class="button" href={fourthwallShop.url} target="_blank" rel="noopener noreferrer">Visit the shop</a>
      <a class="button button--ghost" href="/work.html">Work with VaporHuman</a>
    </div>
  </PageHero>

  <Band variant="intro" kicker="Storefront routes" title="Three shop states, one clear boundary." id="storefront-title">
    <div class="shop-grid" aria-label="Shop route cards">
      <article class="shop-card">
        <p class="status-label">{fourthwallShop.status}</p>
        <h3>{fourthwallShop.title}</h3>
        <p>{fourthwallShop.body}</p>
        <p class="share-url">{fourthwallShop.url}</p>
        <div class="button-row">
          <a class="button" href={fourthwallShop.url} target="_blank" rel="noopener noreferrer">Open Fourthwall</a>
        </div>
      </article>
      <article class="shop-card">
        <p class="status-label">Connected platform</p>
        <h3>{fourthwallShop.connectedPlatform}</h3>
        <p>
          Purchase and membership alerts can route through StreamElements after
          the Fourthwall app connection and overlay settings are verified.
        </p>
      </article>
      <article class="shop-card">
        <p class="status-label">Future domain route</p>
        <h3>{fourthwallShop.futureDomain}</h3>
        <p>
          The custom shop subdomain is a later provider and DNS gate. The root
          site stays focused on trust, work intake, services, and future product
          routing.
        </p>
      </article>
    </div>
  </Band>

  <Band kicker="Next shop moves" title="Current support route first, branded routing later." id="shop-actions">
    <div class="checkout-grid">
      {shopActions.map((action) => (
        <article class="checkout-card">
          <h3>{action.title}</h3>
          <p>{action.body}</p>
        </article>
      ))}
    </div>
  </Band>

  <Band variant="status" kicker="Custom domain" title="Use a shop subdomain." id="custom-domain" columns>
    <div>
      <p>
        Use <strong>{fourthwallShop.futureDomain}</strong> for Fourthwall so
        vaporhuman.com can stay focused on the main site, service intake, trust
        posture, and future suite routing.
      </p>
      <p>{fourthwallShop.domainGate}</p>
      <p class="principle">Shop link now. Custom domain after provider and DNS approval.</p>
    </div>
  </Band>
</BaseLayout>
