---
import Band from "../components/Band.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import CardGrid from "../components/CardGrid.astro";
import PageHero from "../components/PageHero.astro";

const description =
  "About VaporHuman: a plain-language trust and continuity surface for human-centered AI assistant systems.";

const focusCards = [
  { title: "Boundaries", body: "What the assistant may do, what it must not do, and when the human decides." },
  { title: "Memory", body: "Useful continuity without pretending notes, summaries, or retrieval are perfect." },
  { title: "Handoffs", body: "Clear transitions between humans, agents, tools, repos, and future replacements." },
  { title: "Plain language", body: "Explanations that normal people can challenge, correct, and improve." }
];

const directoryCards = [
  { title: "Newsroom", body: "Future updates should be dated, sourced, and easy to verify. There are no press announcements active yet." },
  { title: "VaporHuman Leadership", body: "A public roster is not published yet. Any future roster should separate human operators from assistant personas." },
  { title: "Career Opportunities", body: "No hiring, recruiting, contractor, or employment opportunities are open through this site." },
  { title: "Investors", body: "No investment offering, capital raise, securities claim, or investor-relations program is active here." },
  { title: "Ethics & Compliance", body: "The current posture is simple: clear boundaries, no authority claims, no hidden data collection, and human approval for sensitive actions." },
  { title: "Events", body: "No public events, webinars, workshops, or appearances are scheduled through this site yet." },
  { title: "Contact VaporHuman", body: "Work requests now use the hosted Tally intake path. No public email address is published yet." }
];
---

<BaseLayout title="About VaporHuman" description={description} canonicalPath="/about.html" currentPath="/about.html">
  <PageHero
    kicker="About"
    title="A human layer for assistant systems."
    lede="VaporHuman gives a name to the discipline of keeping memory, handoffs, approvals, and authority boundaries readable."
    body="It is not trying to make an assistant sound more human. It is trying to keep the actual human visible."
  />

  <Band variant="intro" kicker="Origin sequence" title="The public surface starts with a practical problem." id="origin-title">
    <ol class="origin-sequence" aria-label="Conceptual origin sequence">
      <li>
        <span>01</span>
        <h3>Fragmented sessions</h3>
        <p>Useful assistant work appears in separate windows, tools, repos, and memories.</p>
      </li>
      <li>
        <span>02</span>
        <h3>Lost context</h3>
        <p>Important constraints disappear between sessions, and the next assistant starts with partial evidence.</p>
      </li>
      <li>
        <span>03</span>
        <h3>Human risk</h3>
        <p>When uncertainty is hidden, the human has to reconstruct what is true, private, or still unapproved.</p>
      </li>
      <li>
        <span>04</span>
        <h3>Memory boundaries</h3>
        <p>Continuity becomes useful only when it separates durable notes from raw private material.</p>
      </li>
      <li>
        <span>05</span>
        <h3>Visible handoffs</h3>
        <p>The next person or assistant should see what changed, what was verified, and what remains parked.</p>
      </li>
      <li>
        <span>06</span>
        <h3>Approval gates</h3>
        <p>Public claims, provider changes, payments, accounts, and sensitive work wait for explicit human approval.</p>
      </li>
    </ol>
    <div class="origin-map" aria-hidden="true">
      <span>Fragments</span>
      <span>Threads</span>
      <span>Lanes</span>
      <span>Checkpoint</span>
      <span>Handoff</span>
    </div>
  </Band>

  <Band kicker="Focus areas" title="What VaporHuman pays attention to" id="focus-title">
    <CardGrid cards={focusCards} />
  </Band>

  <Band variant="intro" kicker="About VaporHuman" title="Useful sections, without pretending they are bigger than they are." id="about-directory-title">
    <CardGrid cards={directoryCards} directory />
  </Band>

  <Band variant="boundary" kicker="Current state" title="Early, static public output, and deliberately modest." id="status-title" columns>
    <div>
      <p>
        This site is currently a trust surface with a hosted work-intake link.
        It also links to a Stripe-hosted paid discovery session. It does not
        run analytics, provide regulated advice, process card data directly,
        or announce guaranteed service availability.
      </p>
      <p>
        That restraint is intentional. The first job is to explain the trust
        boundary clearly before adding anything more powerful.
      </p>
    </div>
  </Band>
</BaseLayout>
